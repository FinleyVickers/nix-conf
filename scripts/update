#!/usr/bin/env bash
set -euo pipefail

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)/lib.sh"

ROOT="$(repo_root)"

require_command nix

print_step "Updating flake inputs"
nix "${FLAKE_FEATURE_FLAGS[@]}" flake update "${ROOT}"

print_step "Checking flake"
nix "${FLAKE_FEATURE_FLAGS[@]}" flake check "${ROOT}"
