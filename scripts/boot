#!/usr/bin/env bash
set -euo pipefail

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)/lib.sh"

ROOT="$(repo_root)"
HOST_NAME="${HOST:-nixos}"

require_command nixos-rebuild

print_step "Building NixOS system ${HOST_NAME} for next boot"
sudo nixos-rebuild boot --flake "$(flake_ref "${ROOT}" "${HOST_NAME}")"

